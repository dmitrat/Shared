<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>OutWit.Shared.Logging.Provider.NewRelic</id>
    <version>$version$</version>
    <authors>Dmitry Ratner</authors>
    <description>NewRelic NerdGraph log provider plugin for OutWit hosts. Thin wrapper over OutWit.Common.Logging.NewRelic — registers an ILogQueryProvider that queries NewRelic Logs via NRQL. Drop into the host's @Logging folder and set Logging__ProviderKey=NewRelic.</description>
    <copyright>Copyright © 2026 Dmitry Ratner</copyright>
    <license type="expression">Apache-2.0</license>
    <projectUrl>https://github.com/dmitrat/Shared/tree/main/Logging/OutWit.Shared.Logging.Provider.NewRelic</projectUrl>
    <tags>OutWit Shared Logging Provider NewRelic NerdGraph</tags>
    <readme>README.md</readme>
    <icon>OutWit-logo.png</icon>
    <!-- Custom nuspec doesn't auto-import PackageReference constraints from
         the csproj. Declare them explicitly here so consumers (e.g. WitCloud)
         restore the SAME OutWit.Common.Logging.NewRelic version this Provider
         was compiled against. Without the [2.1.0] exact pin, consumers can
         pull a transitive 2.0.0 (from e.g. OutWit.Identity.Shared) while
         this Provider's PEM references 2.1.0.0 → runtime FileLoadException
         on plugin Initialize. Discovered on engine.omnibuscloud.com 2026-05-27.
         Bump the pin in lockstep when bumping OutWit.Common.Logging.NewRelic. -->
    <dependencies>
      <group targetFramework="net10.0">
        <dependency id="OutWit.Common.Logging.NewRelic" version="[2.1.0]" exclude="Build,Analyzers" />
        <dependency id="OutWit.Common.Logging.Query" version="1.0.0" exclude="Build,Analyzers" />
        <dependency id="OutWit.Common.Plugins.Abstractions" version="1.1.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="README.md" target="\" />
    <file src="OutWit-logo.png" target="\" />
    <file src="NOTICE.txt" target="\" />
    <file src="LICENSE.txt" target="\" />
    <file src="build\OutWit.Shared.Logging.Provider.NewRelic.targets" target="build" />
    <file src="build\OutWit.Shared.Logging.Provider.NewRelic.targets" target="buildTransitive" />
    <file src="..\..\@Logging\Release\newrelic.module\**\*" target="logging\newrelic.module" />
    <file src="bin\Release\net10.0\OutWit.Shared.Logging.Provider.NewRelic.dll" target="lib\net10.0" />
  </files>
</package>
