<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>OutWit.Shared.Logging.Provider.Loki</id>
    <version>$version$</version>
    <authors>Dmitry Ratner</authors>
    <description>Grafana Loki log provider plugin for OutWit hosts. Thin wrapper over OutWit.Common.Logging.Loki — registers an ILogQueryProvider that translates neutral LogQuery requests into LogQL and dispatches them against /loki/api/v1/*. Drop into the host's @Logging folder and set Logging__ProviderKey=Loki.</description>
    <copyright>Copyright © 2026 Dmitry Ratner</copyright>
    <license type="expression">Apache-2.0</license>
    <projectUrl>https://github.com/dmitrat/Shared/tree/main/Logging/OutWit.Shared.Logging.Provider.Loki</projectUrl>
    <tags>OutWit Shared Logging Provider Loki Grafana LogQL</tags>
    <readme>README.md</readme>
    <icon>OutWit-logo.png</icon>
    <!-- See Provider.NewRelic.nuspec for the full rationale — custom nuspec
         needs explicit <dependencies> so consumers restore the exact
         OutWit.Common.Logging.<X> version this Provider was compiled against. -->
    <dependencies>
      <group targetFramework="net10.0">
        <dependency id="OutWit.Common.Logging.Loki" version="[2.0.0]" exclude="Build,Analyzers" />
        <dependency id="OutWit.Common.Logging.Query" version="1.0.0" exclude="Build,Analyzers" />
        <dependency id="OutWit.Common.Plugins.Abstractions" version="1.1.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="README.md" target="\" />
    <file src="OutWit-logo.png" target="\" />
    <file src="NOTICE.txt" target="\" />
    <file src="LICENSE.txt" target="\" />
    <file src="build\OutWit.Shared.Logging.Provider.Loki.targets" target="build" />
    <file src="build\OutWit.Shared.Logging.Provider.Loki.targets" target="buildTransitive" />
    <file src="..\..\@Logging\Release\loki.module\**\*" target="logging\loki.module" />
    <file src="bin\Release\net10.0\OutWit.Shared.Logging.Provider.Loki.dll" target="lib\net10.0" />
  </files>
</package>
