<Project>

  <!--
    Auto-imported by NuGet when a host adds a PackageReference to
    OutWit.Shared.Logging.Provider.Loki. Copies the plugin module folder
    from inside the package into the host's output @Logging/loki.module/,
    where the host's WitPluginLoader<ILogProviderPlugin> picks it up.
  -->

  <Target Name="_CopyLokiLogProvider" AfterTargets="Build">
    <ItemGroup>
      <_LokiLogPluginFiles Include="$(MSBuildThisFileDirectory)..\logging\loki.module\**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(_LokiLogPluginFiles)"
          DestinationFolder="$(OutputPath)@Logging\loki.module\%(RecursiveDir)"
          SkipUnchangedFiles="true" />
  </Target>

  <Target Name="_CopyLokiLogProviderPublish" AfterTargets="Publish">
    <ItemGroup>
      <_LokiLogPluginPubFiles Include="$(MSBuildThisFileDirectory)..\logging\loki.module\**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(_LokiLogPluginPubFiles)"
          DestinationFolder="$(PublishDir)@Logging\loki.module\%(RecursiveDir)"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
