<Project>

  <!--
    Auto-imported by NuGet when a host adds a PackageReference to
    OutWit.Shared.Email.Plugin.Null. Copies the plugin module folder from inside
    the package into the host's output, where WitPluginLoader scans @Plugins/.
  -->

  <Target Name="_CopyNullEmailPlugin" AfterTargets="Build">
    <ItemGroup>
      <_NullEmailPluginFiles Include="$(MSBuildThisFileDirectory)..\plugins\null.module\**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(_NullEmailPluginFiles)"
          DestinationFolder="$(OutputPath)@Plugins\null.module\%(RecursiveDir)"
          SkipUnchangedFiles="true" />
  </Target>

  <Target Name="_CopyNullEmailPluginPublish" AfterTargets="Publish">
    <ItemGroup>
      <_NullEmailPluginPubFiles Include="$(MSBuildThisFileDirectory)..\plugins\null.module\**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(_NullEmailPluginPubFiles)"
          DestinationFolder="$(PublishDir)@Plugins\null.module\%(RecursiveDir)"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
