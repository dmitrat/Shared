<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>OutWit.Shared.Email.Provider.Smtp</id>
    <version>$version$</version>
    <authors>Dmitry Ratner</authors>
    <description>SMTP email transport plugin for OutWit hosts. Covers on-prem mail relays, corporate Exchange, and local dev SMTP catchers (MailHog, Papercut). Uses MailKit. Drop into the host's @Email folder and set Email__ProviderKey=Smtp.</description>
    <copyright>Copyright © 2026 Dmitry Ratner</copyright>
    <license type="expression">Apache-2.0</license>
    <projectUrl>https://github.com/dmitrat/Shared/tree/main/Email/OutWit.Shared.Email.Provider.Smtp</projectUrl>
    <tags>OutWit Shared Email Provider SMTP MailKit</tags>
    <readme>README.md</readme>
    <icon>OutWit-logo.png</icon>
  </metadata>
  <files>
    <file src="README.md" target="\" />
    <file src="OutWit-logo.png" target="\" />
    <file src="NOTICE.txt" target="\" />
    <file src="LICENSE.txt" target="\" />
    <file src="build\OutWit.Shared.Email.Provider.Smtp.targets" target="build" />
    <file src="build\OutWit.Shared.Email.Provider.Smtp.targets" target="buildTransitive" />
    <file src="..\..\@Email\Release\smtp.module\**\*" target="email\smtp.module" />
    <file src="bin\Release\net10.0\OutWit.Shared.Email.Provider.Smtp.dll" target="lib\net10.0" />
  </files>
</package>
